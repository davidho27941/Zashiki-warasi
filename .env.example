# Copy this file to `.env` and adjust values.
# The real `.env` is gitignored; this template is committed.
# All variables are read by pydantic-settings on app startup.

# -------- Database --------
# SQLAlchemy URL (driver-prefixed). LangGraph's PostgresSaver receives a
# stripped libpq form (`postgresql://...`) automatically.
DATABASE_URL=postgresql+psycopg://localhost/zashiki_warasi

# -------- Gmail OAuth --------
# Path to the OAuth 2.0 Client ID file downloaded from Google Cloud
# Console (Desktop app type). Default: ./credentials.json
GMAIL_CREDENTIALS_PATH=credentials.json

# Where to cache the user's refresh token after first-time consent.
# Created with 0600 perms; parent directories are created if missing.
GMAIL_TOKEN_PATH=~/.config/zashiki-warasi/token.json

# Comma-separated OAuth scopes. Read-only is enough for polling +
# analysis; use gmail.modify if you later add label / mark-read tools.
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly

# -------- LLM --------
# Provider: llamacpp | openai | anthropic
# - llamacpp / openai both use ChatOpenAI under the hood
# - anthropic requires `uv add langchain-anthropic` first
LLM_PROVIDER=llamacpp

# OpenAI-compatible base URL.
# llama-server default: http://localhost:8080/v1
# OpenAI cloud:        https://api.openai.com/v1
LLM_BASE_URL=http://localhost:8080/v1

# API key. For local llama.cpp the value is ignored but must be non-empty.
LLM_API_KEY=not-needed

# Model identifier the provider expects.
# For llama.cpp this is usually the GGUF filename.
LLM_MODEL=local-model

# Sampling temperature (0.0 = deterministic, 1.0 = creative).
LLM_TEMPERATURE=0.2

# -------- Telegram notifications --------
# Bot token from @BotFather (format: <bot_id>:<auth_string>).
TELEGRAM_BOT_TOKEN=

# Destination chat — one of:
#   - numeric user id (DM your bot first to surface it)
#   - negative group / supergroup id
#   - @channelusername  (the bot must be an admin of the channel)
TELEGRAM_CHAT_ID=

# Override only for tests / self-hosted bridges.
TELEGRAM_API_BASE=https://api.telegram.org

# Request timeout in seconds for the sendMessage call.
TELEGRAM_TIMEOUT_SECONDS=10.0

# -------- Notion expense mirror (optional) --------
# Internal integration token from notion.so/my-integrations (starts
# with `secret_`). The integration must be granted access to the
# target database via its Share menu in Notion.
NOTION_TOKEN=

# UUID of the target database. Find it by opening the database as a
# full page and copying the id from the URL — the 32-char hex chunk
# before any `?v=`.
NOTION_EXPENSE_DATABASE_ID=

# Leaving NOTION_TOKEN or NOTION_EXPENSE_DATABASE_ID empty disables
# the integration entirely. No Notion calls are attempted; the
# Telegram message simply has no Notion link.

NOTION_TIMEOUT_SECONDS=10.0
